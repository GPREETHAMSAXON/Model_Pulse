# ── Node API (apps/api)
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL
POSTGRES_URL=postgresql://postgres:password@localhost:5432/modelpulse

# ── MongoDB
MONGODB_URI=mongodb://localhost:27017/modelpulse

# ── Auth
JWT_SECRET=your_jwt_secret_min_32_chars_change_this
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ── ML Engine (apps/ml-engine)
ML_ENGINE_URL=http://localhost:8000
ML_ENGINE_SECRET=internal_service_secret_change_this

# ── AI
ANTHROPIC_API_KEY=sk-ant-...

# ── Alerts — Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password

# ── Billing (add later)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Frontend (apps/frontend) — Vite requires VITE_ prefix
VITE_API_URL=http://localhost:4000/api/v1
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
